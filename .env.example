# ── AESCSF v2 Evidence Tracker — on-prem configuration ──────────────────────
#
# Copy this file to .env and fill in your values before running:
#   docker compose up -d
#
# HOW TO FIND THESE VALUES
# ─────────────────────────────────────────────────────────────────────────────
# 1. Sign in to https://portal.azure.com
# 2. Go to "Microsoft Entra ID" → "App registrations" → "+ New registration"
# 3. Name: AESCSF v2 Evidence Tracker
#    Supported account types: Accounts in this organizational directory only
#    Redirect URI: Web → http://<YOUR-SERVER-IP-OR-HOSTNAME>/
# 4. After creation, note the "Application (client) ID" → AESCSF_CLIENT_ID
#    and the "Directory (tenant) ID" → AESCSF_TENANT_ID
# 5. Go to "Expose an API" → "Add a scope":
#    Scope name:  Assessment.ReadWrite
#    Who can consent: Admins and users
#    Display name / Description: Read and write AESCSF assessment data
# 6. Go to "API permissions" → "Add a permission" → "My APIs" →
#    select your app → tick Assessment.ReadWrite → "Grant admin consent"
# ─────────────────────────────────────────────────────────────────────────────

# ── EntraID (Azure AD) SSO ───────────────────────────────────────────────────
# Your Azure AD application (client) GUID
AESCSF_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your Azure AD directory (tenant) GUID
AESCSF_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Storage mode ─────────────────────────────────────────────────────────────
# "api"   — save to the SQLite backend (recommended for on-prem)
# "local" — save to browser localStorage only (no backend needed)
AESCSF_STORAGE_MODE=api

# ── Network ──────────────────────────────────────────────────────────────────
# Port exposed on the host machine
HOST_PORT=80

# Restrict CORS to your deployment hostname (optional but recommended)
# ALLOWED_ORIGIN=https://aescsf.yourcompany.com
